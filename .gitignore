# Miscellaneous
*.class
*.log
*.pyc
*.swp
.DS_Store
.atom/
.build/
.buildlog/
.claude/
.history
.svn/
.swiftpm/
migrate_working_dir/

# IntelliJ related
*.iml
*.ipr
*.iws
.idea/

# The .vscode folder contains launch configuration and tasks you configure in
# VS Code which you may wish to be included in version control, so this line
# is commented out by default.
#.vscode/

# Flutter/Dart/Pub related
**/doc/api/
**/ios/Flutter/.last_build_id
.dart_tool/
.flutter-plugins-dependencies
.pub-cache/
.pub/
/build/
/coverage/

# Symbolication related
app.*.symbols

# Obfuscation related
app.*.map.json

# Android Studio will place build artifacts here
/android/app/debug
/android/app/profile
/android/app/release

# Firebase config (downloaded per-developer from Firebase Console)
ios/Runner/GoogleService-Info.plist
android/app/google-services.json

# CocoaPods (regenerated by `pod install`)
ios/Podfile.lock
ios/Pods/
ios/.symlinks/

# Local backups
*.bak.*

# Android release signing (secret — never commit)
*.jks
*.keystore
key.properties
android/key.properties

# Firebase admin SDK service accounts (secret — never commit)
service-account*.json
firebase-adminsdk-*.json

# Env files
.env
.env.*
!.env.example
