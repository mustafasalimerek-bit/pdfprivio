<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
	<dict>
		<key>CADisableMinimumFrameDurationOnPhone</key>
		<true/>
		<key>CFBundleDevelopmentRegion</key>
		<string>$(DEVELOPMENT_LANGUAGE)</string>
		<key>CFBundleDisplayName</key>
		<string>PDFPrivio</string>
		<key>CFBundleExecutable</key>
		<string>$(EXECUTABLE_NAME)</string>
		<key>CFBundleIdentifier</key>
		<string>$(PRODUCT_BUNDLE_IDENTIFIER)</string>
		<key>CFBundleInfoDictionaryVersion</key>
		<string>6.0</string>
		<key>CFBundleName</key>
		<string>pdfprivio</string>
		<key>CFBundlePackageType</key>
		<string>APPL</string>
		<key>CFBundleShortVersionString</key>
		<string>$(FLUTTER_BUILD_NAME)</string>
		<key>CFBundleSignature</key>
		<string>????</string>
		<key>CFBundleVersion</key>
		<string>$(FLUTTER_BUILD_NUMBER)</string>
		<!-- Document types we accept via "Open in PDFPrivio" / Share Sheet.
		     Lets Mail, WhatsApp, Files, and any UTI-aware app hand off a
		     PDF or an image to us without the user first opening this app
		     and picking a file by hand. -->
		<key>CFBundleDocumentTypes</key>
		<array>
			<dict>
				<key>CFBundleTypeName</key>
				<string>PDF Document</string>
				<key>CFBundleTypeRole</key>
				<string>Editor</string>
				<key>LSHandlerRank</key>
				<string>Alternate</string>
				<key>LSItemContentTypes</key>
				<array>
					<string>com.adobe.pdf</string>
				</array>
			</dict>
			<dict>
				<key>CFBundleTypeName</key>
				<string>Image</string>
				<key>CFBundleTypeRole</key>
				<string>Editor</string>
				<key>LSHandlerRank</key>
				<string>Alternate</string>
				<key>LSItemContentTypes</key>
				<array>
					<string>public.image</string>
				</array>
			</dict>
		</array>
		<!-- URL schemes used to wake the host app from extensions:
		     * ShareMedia-com.erekstudio.pdfprivio — receive_sharing_intent's
		       legacy hook (kept so the CFBundleDocumentTypes path keeps
		       working for "Copy to PDFPrivio").
		     * pdfprivio — our custom PDFPrivioShare Share Extension fires
		       this after dropping a file in App Group/SharedExtensionDrop,
		       and our AppDelegate routes it to ShareExtensionBridge so
		       the Flutter side can drain the drop folder. -->
		<key>CFBundleURLTypes</key>
		<array>
			<dict>
				<key>CFBundleURLName</key>
				<string>com.erekstudio.pdfprivio</string>
				<key>CFBundleURLSchemes</key>
				<array>
					<string>ShareMedia-com.erekstudio.pdfprivio</string>
					<string>pdfprivio</string>
				</array>
			</dict>
		</array>
		<!-- Surface PDFPrivio's Documents folder under "On My iPhone /
		     PDFPrivio" in the Files app so the user can browse to shared
		     PDFs we've imported, and so PDFPrivio-produced output (signed,
		     redacted, etc.) is editable in place. -->
		<key>UIFileSharingEnabled</key>
		<true/>
		<key>LSSupportsOpeningDocumentsInPlace</key>
		<true/>
		<key>LSRequiresIPhoneOS</key>
		<true/>
		<key>UIApplicationSceneManifest</key>
		<dict>
			<key>UIApplicationSupportsMultipleScenes</key>
			<false/>
			<key>UISceneConfigurations</key>
			<dict>
				<key>UIWindowSceneSessionRoleApplication</key>
				<array>
					<dict>
						<key>UISceneClassName</key>
						<string>UIWindowScene</string>
						<key>UISceneConfigurationName</key>
						<string>flutter</string>
						<key>UISceneDelegateClassName</key>
						<string>$(PRODUCT_MODULE_NAME).SceneDelegate</string>
						<key>UISceneStoryboardFile</key>
						<string>Main</string>
					</dict>
				</array>
			</dict>
		</dict>
		<key>UIApplicationSupportsIndirectInputEvents</key>
		<true/>
		<key>UILaunchStoryboardName</key>
		<string>LaunchScreen</string>
		<key>UIMainStoryboardFile</key>
		<string>Main</string>
		<key>UISupportedInterfaceOrientations</key>
		<array>
			<string>UIInterfaceOrientationPortrait</string>
			<string>UIInterfaceOrientationLandscapeLeft</string>
			<string>UIInterfaceOrientationLandscapeRight</string>
		</array>
		<key>UISupportedInterfaceOrientations~ipad</key>
		<array>
			<string>UIInterfaceOrientationPortrait</string>
			<string>UIInterfaceOrientationPortraitUpsideDown</string>
			<string>UIInterfaceOrientationLandscapeLeft</string>
			<string>UIInterfaceOrientationLandscapeRight</string>
		</array>
		<key>NSPhotoLibraryUsageDescription</key>
		<string>PDFPrivio reads photos only when you pick images to turn into a PDF. Files never leave your device.</string>
		<key>NSCameraUsageDescription</key>
		<string>PDFPrivio uses the camera when you scan a document or capture an image for a PDF. Captures stay on this device.</string>
		<key>NSUserTrackingUsageDescription</key>
		<string>PDFPrivio uses this only to show ads that are more relevant to you. Your PDF content is never shared — we just ask AdMob to count an anonymous device ID for ad measurement. You can decline and PDFPrivio still works the same.</string>
		<!-- Real PDFPrivio iOS AdMob App ID (publisher pub-7294127185571156).
		     Registered 2026-05-16 for bundle com.erekstudio.pdfprivio.
		     Unit IDs in lib/core/ads/ad_unit_ids.dart. -->
		<key>GADApplicationIdentifier</key>
		<string>ca-app-pub-7294127185571156~2630343438</string>
		<key>SKAdNetworkItems</key>
		<array>
			<dict>
				<key>SKAdNetworkIdentifier</key>
				<string>cstr6suwn9.skadnetwork</string>
			</dict>
		</array>
		<key>UIStatusBarHidden</key>
		<false/>
	</dict>
</plist>
